{
  "manifest_version": 3,
  "name": "CV Sync",
  "version": "1.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["*://*.indeed.com/*", "*://*.linkedin.com/*", "https://api.openai.com/*", "https://cv-sync-api.vercel.app/*"],
  "icons": {
    "16": "icons/favicon-16x16.png",
    "32": "icons/favicon-32x32.png",
    "128": "icons/android-chrome-192x192.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/favicon-16x16.png",
      "32": "icons/favicon-32x32.png",
      "128": "icons/android-chrome-192x192.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.indeed.com/*", "*://*.linkedin.com/*"],
      "js": ["src/content/index.ts"]
    }
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' http://localhost:5173; object-src 'self'"
  },
  "web_accessible_resources": [
  {
    "resources": ["assets/*", "src/content/*"],
    "matches": ["*://*.indeed.com/*", "*://*.linkedin.com/*"]
  }
]
}